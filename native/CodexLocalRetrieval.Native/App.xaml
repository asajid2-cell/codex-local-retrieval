<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="CodexLocalRetrieval_Native.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CodexLocalRetrieval_Native">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <Color x:Key="AmoledBlack">#FF000000</Color>
            <Color x:Key="PanelBlack">#FF07080A</Color>
            <Color x:Key="RaisedBlack">#FF101114</Color>
            <Color x:Key="SoftLine">#FF24262D</Color>
            <Color x:Key="TextStrong">#FFF7F7FA</Color>
            <Color x:Key="TextMuted">#FFA6A7AE</Color>
            <Color x:Key="RoseAccent">#FFFB7185</Color>
            <SolidColorBrush x:Key="AmoledBrush" Color="{StaticResource AmoledBlack}" />
            <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelBlack}" />
            <SolidColorBrush x:Key="RaisedBrush" Color="{StaticResource RaisedBlack}" />
            <SolidColorBrush x:Key="LineBrush" Color="{StaticResource SoftLine}" />
            <SolidColorBrush x:Key="TextStrongBrush" Color="{StaticResource TextStrong}" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource RoseAccent}" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
