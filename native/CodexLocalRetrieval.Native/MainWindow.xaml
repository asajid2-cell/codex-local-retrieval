<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="CodexLocalRetrieval_Native.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CodexLocalRetrieval_Native"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Codex Local Retrieval"
    mc:Ignorable="d">
    <Grid Background="{StaticResource AmoledBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="Codex Local Retrieval">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <Frame x:Name="RootFrame" Grid.Row="1" />
    </Grid>
</Window>
