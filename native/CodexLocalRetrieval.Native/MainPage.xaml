<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="CodexLocalRetrieval_Native.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{StaticResource AmoledBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="PillButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextStrongBrush}" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="PrimaryPillButtonStyle" BasedOn="{StaticResource PillButtonStyle}" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="21" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextStrongBrush}" />
        </Style>

        <DataTemplate x:Key="SessionTemplate">
            <Grid MinHeight="40" Padding="12,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Width="14"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource AccentBrush}"
                    Text="{Binding PinGlyph}" />
                <TextBlock
                    Grid.Column="1"
                    MaxLines="1"
                    Text="{Binding DisplayTitle}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    Foreground="{StaticResource TextMutedBrush}"
                    Text="{Binding DisplayDate}" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="308" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="292" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="0,0,1,0"
            Background="{StaticResource AmoledBrush}"
            Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Button
                    x:Name="BackButton"
                    Margin="2,6,0,0"
                    HorizontalAlignment="Left"
                    Click="Back_Click"
                    Style="{StaticResource IconButtonStyle}">
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        FontSize="18"
                        Glyph="&#xE72B;" />
                </Button>

                <TextBox
                    x:Name="SearchBox"
                    Grid.Row="1"
                    Height="42"
                    Margin="0,22,0,14"
                    CornerRadius="12"
                    KeyDown="SearchBox_KeyDown"
                    PlaceholderText="Search chats"
                    TextChanged="SearchBox_TextChanged" />

                <StackPanel Grid.Row="2" Spacing="8">
                    <Button x:Name="ArchiveButton" Click="Nav_Click" Style="{StaticResource PrimaryPillButtonStyle}" Tag="Archive">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Library" />
                            <TextBlock Text="Archive" />
                        </StackPanel>
                    </Button>
                    <Button Click="Nav_Click" Style="{StaticResource PillButtonStyle}" Tag="Search">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Find" />
                            <TextBlock Text="Deep search" />
                        </StackPanel>
                    </Button>
                    <Button Click="Nav_Click" Style="{StaticResource PillButtonStyle}" Tag="Ask">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Message" />
                            <TextBlock Text="Ask archive" />
                        </StackPanel>
                    </Button>
                    <Button Click="Nav_Click" Style="{StaticResource PillButtonStyle}" Tag="Workspaces">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Folder" />
                            <TextBlock Text="Workspaces" />
                        </StackPanel>
                    </Button>
                    <Button Click="Nav_Click" Style="{StaticResource PillButtonStyle}" Tag="Collections">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="AllApps" />
                            <TextBlock Text="Collections" />
                        </StackPanel>
                    </Button>
                    <Button Click="Nav_Click" Style="{StaticResource PillButtonStyle}" Tag="Settings">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Setting" />
                            <TextBlock Text="Settings" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <ListView
                    x:Name="SessionList"
                    Grid.Row="3"
                    Margin="0,18,0,0"
                    Background="Transparent"
                    BorderThickness="0"
                    IsItemClickEnabled="True"
                    ItemClick="SessionList_ItemClick"
                    ItemTemplate="{StaticResource SessionTemplate}"
                    RightTapped="SessionList_RightTapped"
                    SelectionMode="Single" />

                <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8">
                    <SymbolIcon
                        Foreground="{StaticResource TextMutedBrush}"
                        Symbol="Accept" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{StaticResource TextMutedBrush}"
                        Text="Source files stay untouched" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock
                            x:Name="ScreenLabel"
                            FontSize="12"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="Archive reader" />
                        <TextBlock
                            x:Name="TitleText"
                            MaxLines="2"
                            TextTrimming="CharacterEllipsis"
                            FontSize="24"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextStrongBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                        <Button Click="CopyContext_Click" Style="{StaticResource PillButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Copy" />
                                <TextBlock Text="Copy context" />
                            </StackPanel>
                        </Button>
                        <Button Click="Restore_Click" Style="{StaticResource PrimaryPillButtonStyle}">
                            <TextBlock Text="Build restore packet" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1">
                <StackPanel x:Name="MainContent" Padding="28,26" Spacing="18" />
            </ScrollViewer>
        </Grid>

        <Border
            Grid.Column="2"
            Margin="18,26,18,0"
            Padding="16"
            VerticalAlignment="Top"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="1"
            Background="{StaticResource PanelBrush}"
            CornerRadius="12">
            <StackPanel x:Name="RightPanel" Spacing="12">
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextStrongBrush}"
                    Text="Quick actions" />
                <Button Click="CopyContext_Click" Style="{StaticResource PillButtonStyle}" Content="Copy resume prompt" />
                <Button Click="CopyPath_Click" Style="{StaticResource PillButtonStyle}" Content="Copy chat path" />
                <Button Click="CopyCode_Click" Style="{StaticResource PillButtonStyle}" Content="Copy all code" />
                <Button Click="Source_Click" Style="{StaticResource PillButtonStyle}" Content="Inspect raw events" />
                <Button Click="Review_Click" Style="{StaticResource PillButtonStyle}" Content="Add review-later" />
                <TextBlock
                    Margin="0,6,0,0"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextStrongBrush}"
                    Text="Tags" />
                <VariableSizedWrapGrid
                    x:Name="TagsItems"
                    MaximumRowsOrColumns="3"
                    Orientation="Horizontal" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
